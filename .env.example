# Credenciales de Supabase para el ranking global de los juegos.
# Sin estas variables el juego funciona igual, pero el ranking global
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Publicidad (Google AdSense). El publisher id ya viene commiteado en
# src/shared/ads/client.ts (es un valor publico), asi que normalmente no hace falta
# setear nada aca.
# - VITE_ADSENSE_CLIENT: sobreescribe el publisher id (ca-pub-XXXXXXXXXXXXXXXX).
# - VITE_ADS_PLACEHOLDER: "1" para previsualizar los espacios de anuncios con un
#   placeholder visible en desarrollo (npm run dev).
VITE_ADSENSE_CLIENT=
VITE_ADS_PLACEHOLDER=
